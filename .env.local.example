# Supabase — same project as mechanico-frontend
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — bypasses RLS (keep SECRET, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used as the merchant login link in welcome emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ─── Resend (transactional email) ─────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# The "from" address — must be a verified domain in Resend
RESEND_FROM=Mechanico <onboarding@yourdomain.com>
